# MySQL (Docker Compose local — variáveis lidas por docker/docker-compose.yml)
MYSQL_ROOT_PASSWORD=erika03
MYSQL_DATABASE=hibit_dev
MYSQL_PORT=3306

# RabbitMQ (Docker Compose local — variáveis lidas por docker/docker-compose.yml)
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin123
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ASP.NET Core — backend local (override de appsettings)
# Se backend rodar no Windows e Docker no WSL, troque localhost pelo IP do WSL (hostname -I)
ConnectionStrings__DefaultConnection=Server=localhost;Port=3306;Database=hibit_dev;User=root;Password=erika03;
RabbitMQ__Host=localhost
RabbitMQ__Port=5672
RabbitMQ__User=admin
RabbitMQ__Password=admin123
RabbitMQ__Queue=hibit.contact
RabbitMQ__VirtualHost=/

# JWT
Jwt__Secret=local-dev-jwt-secret-key-min-32-chars!!
Jwt__Issuer=Hibit.Api
Jwt__Audience=Hibit.Web
Jwt__ExpirationMinutes=60

# Usuário de aplicação (seed inicial no banco)
AppUser__Username=hibit-app
AppUser__Password=hibit-app-2026

# AES-256 (32 bytes key as Base64, 16 bytes IV as Base64)
Encryption__Key=REPLACE_WITH_BASE64_32_BYTE_KEY
Encryption__Iv=REPLACE_WITH_BASE64_16_BYTE_IV

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:4200

# API
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000
# Produção (King.host): ASPNETCORE_ENVIRONMENT=Production, ASPNETCORE_PATHBASE=/API

# Frontend (rodar manualmente no VS Code — npm start, porta 4200)
NG_APP_API_URL=http://localhost:5000

# Contact / Map
CONTACT_EMAIL=contato@hibit.com.br
MAP_EMBED_URL=https://www.openstreetmap.org/export/embed.html?bbox=-46.6333,-23.5505,-46.6233,-23.5405&layer=mapnik

# Deploy (GitHub Actions — configurar como Secrets, nunca commitar)
# APP_USER_PASSWORD=
# FTP_SERVER=ftp.hibit.com.br
# FTP_USERNAME=hibit
# FTP_PASSWORD=
# MYSQL_PASSWORD=
# RABBITMQ_PASSWORD=
# JWT_SECRET= (min. 32 caracteres)
# ENCRYPTION_KEY= (Base64, 32 bytes)
# ENCRYPTION_IV= (Base64, 16 bytes)

# --- Produção King.host (configurar no painel da hospedagem, NÃO commitar senhas) ---
# ConnectionStrings__DefaultConnection=Server=mysql.hibit.com.br;Port=3306;Database=hibit;User=hibit;Password=***
# RabbitMQ__Host=rabbit.hibit.com.br
# RabbitMQ__Port=5672
# RabbitMQ__User=admin
# RabbitMQ__Password=***
# RabbitMQ__Queue=hibit.contact
# RabbitMQ__VirtualHost=/
# ASPNETCORE_PATHBASE=/API
# CORS_ORIGINS=https://hibit.com.br,https://www.hibit.com.br
